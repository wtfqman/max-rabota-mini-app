# Production-ready example for app.rabst24.ru.
# Do not switch the real service to final production mode until SSL is issued.

# API runtime.
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
APP_DOMAIN=app.rabst24.ru
APP_URL=https://app.rabst24.ru
WEB_APP_URL=https://app.rabst24.ru
API_PUBLIC_URL=https://app.rabst24.ru/api
TRUST_PROXY=loopback
HTTPS_ENABLED=false
DEV_AUTH_ENABLED=false
CORS_ORIGIN=https://app.rabst24.ru

DATABASE_URL=postgresql://rabst24:change_me@postgres:5432/rabst24?schema=public

# MAX API and bot runtime.
MAX_BOT_TOKEN=replace_me
MAX_API_BASE_URL=https://platform-api.max.ru

# Keep long-polling while SSL is not connected.
# After SSL is ready you can switch to webhook and set the MAX webhook URL to:
# https://app.rabst24.ru/webhooks/max
# Also set HTTPS_ENABLED=true after SSL is active on app.rabst24.ru.
MAX_BOT_MODE=long-polling
MAX_WEBHOOK_PATH=/webhooks/max
MAX_WEBHOOK_SECRET=replace-with-letters-numbers-dash-or-underscore
MAX_INIT_DATA_MAX_AGE_SECONDS=86400
MAX_LONG_POLLING_TIMEOUT_SECONDS=30
MAX_LONG_POLLING_LIMIT=100
MAX_CHANNEL_CHAT_ID=

SESSION_SECRET=replace_with_at_least_32_random_characters
SESSION_TTL_SECONDS=3600

MINI_APP_URL=https://app.rabst24.ru
CHANNEL_URL=

# Frontend build config.
VITE_APP_URL=https://app.rabst24.ru
VITE_API_BASE_URL=https://app.rabst24.ru/api
VITE_APP_BASE_PATH=/
VITE_DEV_AUTH_ENABLED=false

# Future separate API-domain option:
# CORS_ORIGIN=https://app.rabst24.ru
# API_PUBLIC_URL=https://api.rabst24.ru/api
# VITE_API_BASE_URL=https://api.rabst24.ru/api
