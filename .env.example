# Local development example. Production values are in .env.production.example.
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
APP_DOMAIN=localhost
APP_URL=http://localhost:5173
WEB_APP_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000/api
TRUST_PROXY=false
HTTPS_ENABLED=false
DEV_AUTH_ENABLED=true
DEV_AUTH_MAX_USER_ID=9000000001
DEV_AUTH_USERNAME=local_dev
DEV_AUTH_FIRST_NAME=Local
DEV_AUTH_LAST_NAME=Developer
CORS_ORIGIN=http://localhost:5173

DATABASE_URL=file:./dev.db

MAX_BOT_TOKEN=replace_me
MAX_API_BASE_URL=https://platform-api.max.ru
MAX_BOT_MODE=long-polling
MAX_WEBHOOK_PATH=/webhooks/max
MAX_WEBHOOK_SECRET=replace-with-letters-numbers-dash-or-underscore
MAX_INIT_DATA_MAX_AGE_SECONDS=86400
MAX_LONG_POLLING_TIMEOUT_SECONDS=30
MAX_LONG_POLLING_LIMIT=100
MAX_CHANNEL_CHAT_ID=
MAX_MINI_APP_WEB_APP=

SESSION_SECRET=replace_with_at_least_32_random_characters
SESSION_TTL_SECONDS=3600

MINI_APP_URL=http://localhost:5173
CHANNEL_URL=

VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=/api
VITE_APP_BASE_PATH=/
VITE_DEV_AUTH_ENABLED=true
VITE_DEV_API_PROXY_TARGET=http://localhost:3000
